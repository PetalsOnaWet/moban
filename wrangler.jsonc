{
  "name": "moban",
  "compatibility_date": "2024-04-03",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".open-next/assets",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "moban_db",
      "database_id": "placeholder-id"
    }
  ]
}
